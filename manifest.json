{
  "manifest_version": 3,
  "name": "Company Highlighter",
  "version": "1.0",
  "description": "Highlights company names on any website",
  "permissions": [],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["companies.txt"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
